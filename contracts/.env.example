# LitVM LiteForge testnet — https://docs.litvm.com/get-started-on-testnet/add-to-wallet
LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/http

# Optional: official wrapped native on 4441 (e.g. WzkLTC). If unset, deploy deploys WETH9Mock for the gateway.
# LITVM_WRAPPED_NATIVE_TOKEN=

# Optional: override Aave oracle address for npm run test:litvm-oracle (defaults to deployments/litvmLiteforge/AaveOracle-Prydox.json)
# LITVM_AAVE_ORACLE=

# Deployer: 0x-prefixed private key (fund with testnet zkLTC for gas). Never commit real keys.
DEPLOYER_PRIVATE_KEY=

# Market config name (Prydox = contracts/markets/prydox — USDC, LTC, ZKLT; receipt symbols pUSDC, pLTC, pZKLT).
MARKET_NAME=Prydox

# --- On-chain feeds + reserves on LiteForge (no Aave mock-aggregator deploy path) ---
# 1) Deploy three Chainlink-compatible feeds (owner-updatable until you use official feeds):
#    npm run deploy:litvm-feeds
# 2) Set PRYDOX_LITVM_PRODUCTION=true and set LITVM_FEED_* to your oracle addresses.
# 3) Set LITVM_TOKEN_* to your reserve ERC20s on 4441 (example: prior Prydox testnet deploy):
#    USDC 0x94f3BF60D0FDD920467815570B78a2F494D92566
#    LTC  0x6D91307931a77C897D544A5E698cb1eA18009f32
#    ZKLT 0x571b17015e46612D882b50aafC58A1b5E6b3D63a
# 4) Deploy the market: npm run deploy:litvm
#    If the RPC returns "Too Many Requests", wait and run npm run deploy:litvm again (resume; no --reset).
#    Full reset: npm run deploy:litvm:reset
# Optional: LITVM_INITIAL_PRICE_USDC, LITVM_INITIAL_PRICE_LTC, LITVM_INITIAL_PRICE_ZKLT (8 decimals).
# PRYDOX_LITVM_PRODUCTION=false
# LITVM_TOKEN_USDC=
# LITVM_TOKEN_LTC=
# LITVM_TOKEN_ZKLT=
# LITVM_FEED_USDC=0xb0f3cFABe04d838EDAC4272c6B4647c693CdA5Fd
# LITVM_FEED_LTC=0xD3a7687364bDE392E4365c043c599042708CDDB5
# LITVM_FEED_ZKLT=0xD3a7687364bDE392E4365c043c599042708CDDB5
#
# --- Push Chainlink spot prices into LitVM ManualAggregatorFeed (after deploy:litvm-feeds) ---
# Reads AggregatorV3 on the same network as CHAINLINK_RPC_URL (default: Base mainnet).
# --- Mint test USDC on-chain (no balance needed) ---
# npm run deploy:litvm-mint-usdc
# LITVM_MINT_TEST_USDC=
#
# --- Testnet faucet (transfer from pool, not mint) ---
# npm run deploy:litvm-faucet
# npm run fund:litvm-faucet   (requires deployer USDC + zkLTC; tune FAUCET_SEED_*)
# LITVM_FAUCET=
#
# npm run update:litvm-feeds-chainlink
# CHAINLINK_RPC_URL=https://mainnet.base.org
# CHAINLINK_FEED_USDC=0x7e860098F58bBFC8648a4311b374B1D669a2bc6B
# CHAINLINK_FEED_LTC=0x206a34e47093125fbf4C75b7c7E88b84c6A77a69
# Optional: CHAINLINK_FEED_ZKLT (defaults to same feed as LTC)
