# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example committable)
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# solidity / prydox contracts (isolated from Next.js)
contracts/node_modules/
contracts/cache_hardhat/
contracts/artifacts_hardhat/
contracts/out/
contracts/broadcast/
contracts/cache/

# Incomplete git vendor dirs (optional cleanup)
contracts/lib/**/.git/
