# Next.js — copy to .env.local and adjust after redeploys.
# Wallet: injected EVM wallet (MetaMask, Rabby, …). Chain 4441 = LitVM LiteForge.
NEXT_PUBLIC_CHAIN_ID=4441
NEXT_PUBLIC_LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/http
# Optional websocket endpoint for push/block updates (falls back to HTTP if unavailable)
NEXT_PUBLIC_LITVM_WS_URL=wss://liteforge.rpc.caldera.xyz/ws
# WalletConnect Cloud project id (required by RainbowKit for mobile/walletconnect flows)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
# Borrow limit basis points (e.g. 7000 = 70% LTV)
NEXT_PUBLIC_BORROW_LTV_BPS=7000
# Docs (defaults to https://prydox.finance/docs)
NEXT_PUBLIC_DOCS_URL=https://prydox.finance/docs
# Optional — footer “Community” links
# NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/prydox
# NEXT_PUBLIC_TWITTER_URL=https://twitter.com/your_handle

# From contracts/deployments/litvmLiteforge/*.json after `npm run deploy:litvm` completes
NEXT_PUBLIC_POOL_ADDRESSES_PROVIDER=0xB10BA4c4d1A0b4b092550325C0fD30E2aaC9840F
NEXT_PUBLIC_POOL=0xe069F6DdF99b120490B1c28E1e1E0FDbAEb2A39c
NEXT_PUBLIC_ORACLE=0xCe6BbD5518DE8Eff358CE46cEc054aD854e72518
NEXT_PUBLIC_POOL_DATA_PROVIDER=0xFbb0e62504E7ff80babf0ff25fb6026a0797bb9E
# WrappedTokenGatewayV3 — native zkLTC → pool (see deployments)
NEXT_PUBLIC_WRAPPED_TOKEN_GATEWAY=0x0AA5a605Ab587c4dbfa3179225b7c9ca86678968

# Reserve ERC20 + price feeds (ManualAggregatorFeed redeploy — Chainlink-shaped latestRoundData)
# USDC underlying (6 decimals) — wallet balance + deposits use this contract
NEXT_PUBLIC_TOKEN_USDC=0xe1b51EfB42cC9748C8ecf1129705F5d27901261a
# NEXT_PUBLIC_TOKEN_LTC=
# NEXT_PUBLIC_TOKEN_ZKLT=
NEXT_PUBLIC_FEED_USDC=0x1749DB9dA7EfDd3C07cB3c08e8Ca258d8Fa2970e
NEXT_PUBLIC_FEED_LTC=0x4F62A61bA4b268e05bca0dD7Db4dB7AeC3E872b9
NEXT_PUBLIC_FEED_ZKLT=0xBACFca1C8B226EEAfb14911E3Dc72260E6c904d1
